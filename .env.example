# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Public HTTPS base URL (used to build Twilio webhook + WebSocket URLs)
# In prod: https://your-domain.com   |  local dev: use ngrok https URL
BASE_URL=https://your-ngrok-or-domain.com

NODE_ENV=development
LOG_LEVEL=info

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Optional: validate webhook signatures (recommended in production)
TWILIO_WEBHOOK_SECRET=your_webhook_signing_secret

# ── Deepgram (ASR + TTS) ──────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_ASR_MODEL=nova-3
# Silence duration (ms) Deepgram waits before firing speech_final
DEEPGRAM_ENDPOINTING=400

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=512

# ── OpenAI (embeddings only) ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=voice-ai-kb

# ── Redis (Upstash or Redis Cloud) ────────────────────────────────────────────
REDIS_URL=rediss://default:your_password@your-upstash-host.upstash.io:6380

# ── Call behaviour ────────────────────────────────────────────────────────────
MAX_CALL_DURATION_MINUTES=10
# How many user+assistant turn pairs to keep in LLM context
CONVERSATION_HISTORY_TURNS=12
# Filler audio fires if KB retrieval takes longer than this (ms)
FILLER_AUDIO_TIMEOUT_MS=650
# LLM call timeout before fallback + transfer
LLM_TIMEOUT_MS=2000

# ── Agent transfer ────────────────────────────────────────────────────────────
# PSTN number of the human agent queue / softphone to dial for warm transfers
AGENT_PHONE_NUMBER=+1XXXXXXXXXX
