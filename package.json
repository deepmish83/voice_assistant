{
  "name": "voice-ai-server",
  "version": "1.0.0",
  "description": "API-only outbound voice AI — Stack A (cost-optimised)",
  "private": true,
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "dev":   "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint":  "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk":          "^0.27.0",
    "@pinecone-database/pinecone": "^3.0.0",
    "express":                    "^4.19.0",
    "ioredis":                    "^5.3.0",
    "openai":                     "^4.52.0",
    "pino":                       "^9.0.0",
    "pino-pretty":                "^11.0.0",
    "twilio":                     "^5.3.0",
    "ws":                         "^8.17.0"
  },
  "devDependencies": {
    "@types/express":  "^4.17.0",
    "@types/node":     "^20.0.0",
    "@types/ws":       "^8.5.0",
    "ts-node-dev":     "^2.0.0",
    "typescript":      "^5.4.0"
  }
}
